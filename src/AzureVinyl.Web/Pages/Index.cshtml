@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
    ViewData["EnvironmentName"] = Model.EnvironmentName;
}

<div class="text-center">
    <div class="container">
        <div class="row">
            @foreach (Vinyl vinyl in Model.Vinyls)
            {
                <div class="col-md-3">
                    <a href="/Edit/@vinyl.Id">
                        <img src="@vinyl.AlbumArtUrl" alt="@vinyl.Title" class="img-fluid" />
                    </a>
                    <p>@vinyl.Title - @vinyl.Artist (@vinyl.Year)</p>
                </div>
            }
        </div>
    </div>
</div>
